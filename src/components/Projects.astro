---
// Projects.astro – Grid de proyectos con cards
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const projects = [
  {
    num: '01',
    title: t('projects.items.teampoza.title'),
    desc: t('projects.items.teampoza.desc'),
    tags: t('projects.items.teampoza.tags'),
    href: 'https://teampoza.dev',
    featured: true,
  },
  {
    num: '02',
    title: t('projects.items.animegratis.title'),
    desc: t('projects.items.animegratis.desc'),
    tags: t('projects.items.animegratis.tags'),
    href: 'https://animegratis.es',
    featured: true,
  },
];
---

<section id="projects" class="section" aria-label={t('projects.label')}>
  <span class="section-label">{t('projects.label')}</span>
  <h2 class="section-title reveal">{t('projects.title')}</h2>

  <div class="projects-grid">
    {projects.map((p) => (
      <a href={p.href} target="_blank" rel="noopener noreferrer"
        class={`project-card reveal${p.featured ? ' project-featured' : ''}`}
        aria-label={`${t('projects.viewProject')}${p.title}`}>
        <div class="project-card-top">
          <span class="project-num">— {p.num}</span>
          {p.featured && <span class="project-badge">{t('projects.featured')}</span>}
        </div>
        <h3 class="project-title">{p.title}</h3>
        <p class="project-desc">{p.desc}</p>
        <div class="project-footer">
          <div class="project-tags">
            {Array.isArray(p.tags) ? p.tags.map((tag: string) => <span class="project-tag">{tag}</span>) : null}
          </div>
          <div class="project-arrow" aria-hidden="true">↗</div>
        </div>
      </a>
    ))}
  </div>
</section>
