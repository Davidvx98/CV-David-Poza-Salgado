---
// Secuencia: solapa triangular sube → carta emerge → tarjeta de bienvenida
---

<div id="intro-overlay">
  <div class="envelope-wrap" id="envelope" role="button" tabindex="0"
    aria-label="Abrir el sobre" aria-describedby="click-hint">
    <div class="envelope-body" aria-hidden="true"></div>
    <div class="env-fold-bottom" aria-hidden="true"></div>
    <div class="env-fold-left" aria-hidden="true"></div>
    <div class="env-fold-right" aria-hidden="true"></div>
    <div class="envelope-letter" aria-hidden="true"></div>

    <!-- La única pieza móvil: el triángulo superior. -->
    <div class="envelope-flap" id="flap" aria-hidden="true">
      <div class="envelope-flap-face"></div>
    </div>

    <!-- El sello es independiente de la solapa y permanece fijo sobre ella. -->
    <div class="envelope-seal" aria-hidden="true">
      <svg viewBox="0 0 80 80" width="64" height="64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="40" cy="40" r="34" fill="#cc1b1b" opacity="0.22"/>
        <circle cx="40" cy="40" r="28" fill="#cc1b1b" opacity="0.30"/>
        <path d="M40 8 L43.5 30 L64 18 L50 36 L72 40 L50 44 L64 62 L43.5 50 L40 72 L36.5 50 L16 62 L30 44 L8 40 L30 36 L16 18 L36.5 30 Z"
          fill="#e02020" opacity="0.95"/>
        <circle cx="40" cy="40" r="34" stroke="#e02020" stroke-width="1.4" opacity="0.6"/>
        <text x="40" y="46" text-anchor="middle" font-family="serif" font-size="18"
          font-weight="700" fill="#fff" opacity="0.95">D</text>
      </svg>
    </div>
  </div>

  <p class="click-hint" id="click-hint">Haz click para abrir</p>
</div>

<div class="inner-card" id="inner-card" aria-live="polite">
  <span class="inner-card-label">Para ti</span>
  <p>
    <strong>Bienvenido al perfil de David&nbsp;Poza,</strong>
    Web Developer especializado en experiencias web rápidas, limpias y bien diseñadas.
  </p>
  <button class="btn-enter" id="enter-btn" aria-label="Entrar al portfolio">
    Entrar al perfil
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5"
        stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</div>

<button class="skip-btn" id="skip-btn" aria-label="Saltar introducción">Saltar intro</button>
<div id="build-scan" aria-hidden="true"></div>

<script>
  import { gsap } from 'gsap';

  const overlay = document.getElementById('intro-overlay')!;
  const envelope = document.getElementById('envelope')!;
  const flap = document.getElementById('flap')!;
  const letter = envelope.querySelector<HTMLElement>('.envelope-letter')!;
  const clickHint = document.getElementById('click-hint')!;
  const card = document.getElementById('inner-card')!;
  const enterBtn = document.getElementById('enter-btn')!;
  const skipBtn = document.getElementById('skip-btn')!;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const shouldSkipIntro = localStorage.getItem('intro-disabled') === '1' || prefersReducedMotion.matches;
  let opened = false;
  let entering = false;
  let introTimeline: gsap.core.Timeline | null = null;

  function completeIntro() {
    introTimeline?.kill();
    overlay.remove();
    card.remove();
    skipBtn.remove();
    document.body.classList.add('is-built');
    document.body.style.overflow = '';
    window.dispatchEvent(new CustomEvent('portfolioEntered'));
  }

  function openEnvelope() {
    if (opened || shouldSkipIntro) return;
    opened = true;
    envelope.setAttribute('aria-disabled', 'true');

    introTimeline = gsap.timeline({ defaults: { overwrite: 'auto' } });
    introTimeline
      .to(clickHint, { opacity: 0, duration: 0.18, ease: 'power1.out' }, 0)
      // scaleY negativo repliega el mismo triángulo hacia arriba desde la bisagra.
      .to(flap, {
        scaleY: -1,
        duration: 0.68,
        ease: 'power2.inOut',
        transformOrigin: '50% 0%',
      }, 0.08)
      .set(flap, { zIndex: 3 }, 0.76)
      .to(letter, {
        yPercent: -72,
        opacity: 1,
        duration: 0.62,
        ease: 'power3.out',
      }, 0.62)
      .to(letter, {
        yPercent: -98,
        duration: 0.34,
        ease: 'power2.out',
      }, 1.05)
      .fromTo(card, {
        top: '56%',
        xPercent: -50,
        yPercent: 0,
        opacity: 0,
      }, {
        top: '50%',
        yPercent: -50,
        opacity: 1,
        duration: 0.72,
        ease: 'power3.out',
        onStart: () => card.classList.add('card-visible'),
      }, 1.1)
      .to(envelope, {
        opacity: 0,
        y: 20,
        duration: 0.5,
        ease: 'power2.in',
        onComplete: () => envelope.remove(),
      }, 1.28);
  }

  function enterPortfolio() {
    if (entering || shouldSkipIntro) return;
    entering = true;
    introTimeline?.kill();
    introTimeline = gsap.timeline({ defaults: { overwrite: 'auto' } })
      .to([overlay, card], { opacity: 0, duration: 0.5, ease: 'power1.out' })
      .call(completeIntro);
  }

  if (shouldSkipIntro) {
    completeIntro();
  } else {
    document.body.style.overflow = 'hidden';
    envelope.addEventListener('click', openEnvelope);
    envelope.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        openEnvelope();
      }
    });
    enterBtn.addEventListener('click', enterPortfolio);
    skipBtn.addEventListener('click', enterPortfolio);
  }
</script>
