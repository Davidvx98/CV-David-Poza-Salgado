// Lista plana de todos los skills para la leyenda
const allSkills = groups.flatMap(g => g.skills);
---

<section id="skills" class="section" aria-label={t('skills.label')}>
  <span class="section-label">{t('skills.label')}</span>
  <h2 class="section-title reveal">{t('skills.title')}</h2>

  <div class="skills-groups">
    {groups.map((g) => (
      <div class="skill-group reveal">
        <div class="skill-group-title">{g.name}</div>
        <!-- Hint: fades out once the card is activated -->
        <p class="skill-hint" aria-hidden="true">
          <span class="skill-hint-desktop">{lang === 'es' ? 'Pasa el ratón para ver' : 'Hover to see'}</span>
          <span class="skill-hint-mobile">{lang === 'es' ? 'Toca la tarjeta para ver' : 'Tap the card to see'}</span>
        </p>
        <ul class="skill-list" role="list">
          {g.skills.map((s) => (
            <li class="skill-item">
              <span class="skill-icon" aria-label={s.name} title={s.name}
                set:html={logos[s.id] ?? ''} />
              <div class="skill-dots" aria-label={`${s.name}: ${s.level} ${lang === 'es' ? 'de' : 'of'} 10`}>
                {Array.from({length: 10}, (_, i) => (
                  <span
                    class={`skill-dot${i < s.level ? ' filled' : ''}`}
                    style={i < s.level ? `--di:${i * 0.06}s` : ''}
                  ></span>
                ))}
              </div>
              <span class="skill-score">
                {s.level}<span class="skill-score-max">/10</span>
              </span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <!-- Leyenda colapsable: botón "Ver leyenda" --> 
  <div class="skills-legend reveal">
    <button class="legend-toggle" id="legendToggle" aria-expanded="false" aria-controls="legendGrid">
      <svg class="legend-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {lang === 'es' ? 'Ver leyenda' : 'View legend'}
    </button>
    <div class="skills-legend-grid" id="legendGrid" aria-hidden="true">
      {allSkills.map((s) => (
        <span class="legend-item">
          <span set:html={logos[s.id] ?? ''} />
          {s.name}
        </span>
      ))}
    </div>
  </div>
</section>

<script>
  const btn  = document.getElementById('legendToggle') as HTMLButtonElement;
  const grid = document.getElementById('legendGrid')   as HTMLElement;

  btn.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    grid.setAttribute('aria-hidden', String(open));
    btn.classList.toggle('is-open', !open);
  });
</script>

<script>
  const groups = document.querySelectorAll<HTMLElement>('.skill-group');

  // IntersectionObserver: only marks visible (for other reveal animations, NOT for dots)
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.2 }
  );

  groups.forEach((group) => {
    observer.observe(group);

    // Desktop: hover reveals dots
    group.addEventListener('mouseenter', () => group.classList.add('active'));
    group.addEventListener('mouseleave', () => group.classList.remove('active'));

    // Mobile: tap toggles dots — only if touch didn't scroll
    let touchStartY = 0;
    group.addEventListener('touchstart', (e) => {
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    group.addEventListener('touchend', (e) => {
      const delta = Math.abs(e.changedTouches[0].clientY - touchStartY);
      if (delta < 10) group.classList.toggle('active'); // tap, not scroll
    }, { passive: true });
  });
</script>
